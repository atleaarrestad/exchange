{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Simulation": {
    "Enabled": false
  },
  "CryptoTransactions": {
    "Idempotency": {
      "SqliteConnectionString": "Data Source=exchange-crypto-idempotency.db",
      "TimeoutReconciliation": {
        "ScanIntervalSeconds": 30,
        "StaleAfterSeconds": 45
      }
    },
    "Gateways": {
      "Kraken": {
        "Enabled": false,
        "BaseUrl": "https://api.kraken.com",
        "HttpTimeoutSeconds": 15,
        "ApiKey": "",
        "ApiSecret": "",
        "BitcoinWithdrawalKey": "btc-default",
        "EtherWithdrawalKey": "eth-default",
        "BitcoinRequiredConfirmations": 3,
        "EtherRequiredConfirmations": 12
      }
    },
    "Simulation": {
      "MinLatencyMs": 20,
      "MaxLatencyMs": 120,
      "RejectRate": 0.02,
      "TimeoutRate": 0.01,
      "DefaultBitcoinAvailableBalance": 2.0,
      "DefaultEtherAvailableBalance": 20.0
    }
  },
  "AllowedHosts": "*"
}
