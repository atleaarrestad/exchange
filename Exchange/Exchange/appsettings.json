{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Simulation": {
    "Enabled": false
  },
  "CryptoTransactions": {
    "Idempotency": {
      "SqliteConnectionString": "Data Source=exchange-crypto-idempotency.db"
    },
    "Simulation": {
      "MinLatencyMs": 20,
      "MaxLatencyMs": 120,
      "RejectRate": 0.02,
      "TimeoutRate": 0.01
    }
  },
  "AllowedHosts": "*"
}
