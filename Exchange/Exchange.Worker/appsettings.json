{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Simulation": {
    "Enabled": false
  },
  "Messaging": {
    "Transport": "rabbitmq",
    "RabbitMq": {
      "Host": "localhost",
      "VirtualHost": "/",
      "Username": "guest",
      "Password": "guest"
    }
  },
  "CryptoTransactions": {
    "Idempotency": {
      "ConnectionString": "Host=localhost;Port=5432;Database=exchange;Username=exchange;Password=exchange_dev_password",
      "TimeoutReconciliation": {
        "ScanIntervalSeconds": 30,
        "StaleAfterSeconds": 45
      }
    },
    "Gateways": {
      "Kraken": {
        "Enabled": false,
        "BaseUrl": "https://api.kraken.com",
        "HttpTimeoutSeconds": 15,
        "ApiKey": "",
        "ApiSecret": "",
        "BitcoinWithdrawalKey": "btc-default",
        "EtherWithdrawalKey": "eth-default",
        "BitcoinRequiredConfirmations": 3,
        "EtherRequiredConfirmations": 12
      }
    },
    "Resilience": {
      "BlockchainGateway": {
        "Enabled": true,
        "OperationTimeoutSeconds": 20,
        "FailureRatio": 0.5,
        "MinimumThroughput": 20,
        "SamplingDurationSeconds": 30,
        "BreakDurationSeconds": 30,
        "MaxParallelization": 32,
        "MaxQueueingActions": 64
      }
    },
    "BrokeredTrading": {
      "QuoteTtlSeconds": 15,
      "InternalOnlySpreadBasisPoints": 35.0,
      "ExternalHedgeSpreadBasisPoints": 90.0,
      "MaxAllowedSlippageBasisPoints": 200.0,
      "MaxBufferedHedgeCustomerBuys": 10,
      "MaxBufferedHedgeDelaySeconds": 30
    },
    "Simulation": {
      "DefaultBitcoinAvailableBalance": 2.0,
      "DefaultEtherAvailableBalance": 20.0
    }
  }
}
